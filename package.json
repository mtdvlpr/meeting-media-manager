{
  "name": "meeting-media-manager",
  "version": "24.9.0-alpha.o",
  "private": true,
  "main": "dist-electron/main.js",
  "description": "Meeting Media Manager",
  "homepage": "https://sircharlo.github.io/meeting-media-manager/",
  "bugs": "https://github.com/sircharlo/meeting-media-manager/issues",
  "license": "AGPL-3.0-or-later",
  "author": {
    "name": "sircharlo",
    "email": "sircharlo@gmail.com",
    "url": "https://github.com/sircharlo/"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/mtdvlpr/meeting-media-manager.git"
  },
  "scripts": {
    "pre-build": "yarn prepare && ts-node -T pre-build.ts",
    "dev": "yarn pre-build && NODE_OPTIONS='--no-warnings' nuxi dev",
    "prepare": "NODE_OPTIONS='--no-warnings' nuxi prepare",
    "analyze": "cross-env NODE_OPTIONS='--no-warnings' nuxi analyze",
    "build-dev": "yarn build --c electron-builder-dev.yml",
    "build": "yarn pre-build && cross-env NODE_OPTIONS='--no-warnings' nuxi generate && electron-builder",
    "lint:js": "eslint --ext \".js,.ts,.vue\" --ignore-path .gitignore .",
    "lint:prettier": "prettier --check .",
    "lint": "yarn lint:js && yarn lint:prettier",
    "lint:fix": "prettier --write --list-different . && yarn lint:js --fix",
    "test": "xvfb-maybe -- playwright test"
  },
  "engines": {
    "node": "^20.11.1",
    "yarn": "^4.1.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "resolutions": {
    "vue": "3.4.19"
  },
  "packageManager": "yarn@4.1.0",
  "dependencies": {
    "@sentry/electron": "^4.18.0",
    "dotenv": "^16.4.5",
